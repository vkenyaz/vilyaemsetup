#!/bin/sh
############################################
# Description - DWM Status Bar in POSIX
# Author - Vilyaem
############################################

while true; do

cl
DATE="$(date -I)$(printf " " ; date | awk '{print $1 " " $4}')" # Current Date
WEATHER=$(curl -s "wttr.in/Detroit?format=1") # Current Weather
XMR=$(curl -s "rate.sx/XMR@1h" | awk '/avg/ {print $2}' | sed 's/\x1b\[[0-9;]*m//g') # XMR Crypto Price
DSK=$(df -h / | awk "/dev/" | awk '{print $4" "$5}') # Disk Usage, now works for ssd/hdd/nvme
BAT=$(cat /sys/class/power_supply/BAT0/capacity) # Battery Capacity
VOTD=$( # Local Random Scripture Verse
      BOOK=$(kjv -l | awk '{ if (length($1) > 3) print $1}' | shuf -n 1)   ;  \
      printf "%s" $BOOK ; \
      NUM=$(kjv "$(echo "$BOOK")" \
      | awk '{print $1}' \
      | awk '/[0-9]:[0-9]/'  \
      | shuf -n 1); printf " %s" "$NUM") \

# Handle when I plug in a monitor.
# Get the status of the VGA1 display
VGA_STATUS=$(xrandr | grep "VGA1 connected")
# Check if VGA1 is connected
if [ -n "$VGA_STATUS" ]; then
    # Set VGA1 as the primary display
    xrandr --output VGA1 --primary --auto --output LVDS1 --off
    #printf "VGA1 is now set as the primary display.\n"
else
    #printf "VGA1 is not connected.\n"
    xrandr -s 1280x720 --output LVDS1 --primary --auto --output VGA1 --off
fi

## If weather fails, say it failed
echo "$WEATHER" | grep "location" && WEATHER="☁ NULL"


BAR="☦️[⌚$DATE][📖$VOTD][$WEATHER][💿$DSK][🔋$BAT]"

#non-unicode version
#BAR="+[D:$DATE][V:$VOTD][W:$WEATHER][XMR:$XMR][DSK:$DSK][B:$BAT]"

#printf "%s\n", "$BAR"

xsetroot -name "$BAR" 

sleep 60
done
