#!/bin/env zsh
pgrep tmux && tmux a
session="work"
tmux new-session -d -s work nvim ~/k/{journal/$(date -I).md,index.md,wiki/readme.md}

tmux rename-window -t $session:1 'sigma'
tmux split-window -v -p 20 -t $session:1 \; select-pane -T moc
tmux split-window -h -t $session:1 \; select-pane -T vit
tmux new-window -t $session:2 -n 'sys'
tmux split-window -h -t $session:2
tmux new-window -t $session:3 -n 'workshop'

# The first pane is already dealt with
tmux send-keys -t $session:1.2 'sleep 0.2 && moc' C-m
tmux send-keys -t $session:1.3 'task sync ; vit' C-m

tmux send-keys -t $session:2.1 "ncdu --exclude '.*'" C-m
tmux send-keys -t $session:2.2 'glances' C-m

tmux select-window -t $session:1

tmux a
