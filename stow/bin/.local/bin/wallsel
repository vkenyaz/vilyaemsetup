#!/usr/bin/bash
#############################################
# Description - Select a wallpaper, includes Devuan system wallpapers
# Author - Vilyaem
# ###########################################
#WALL=$(\ls /usr/share/images/desktop-base/*.png $HOME/w/*.png $HOME/w/*.jpg $HOME/w/*.jpeg $HOME/w/*.PNG | dmenu -l 30 -p "Select a Wallpaper:" ) || exit 0

WALL=$(\ls /usr/share/images/desktop-base/*.png $HOME/w/*.png $HOME/w/*.jpg $HOME/w/*.jpeg $HOME/w/*.PNG | rofi -dmenu \
    -show-icons \
    # -theme-str 'element-icon-size: 128;' \
    -theme-str 'window {width: 80%; height: 80%;}' \
    -theme-str 'listview {columns: 5; lines: 4;}' \
    -p "Wallpaper:")

[ -z "$WALL" ] && exit 0

xwallpaper --stretch "$WALL"
wal -a 30 "$WALL"
